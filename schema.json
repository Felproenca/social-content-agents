{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "marketingos-references/schema.json",
  "title": "MarketingOS Reference — Full File Schema",
  "description": "Valida arquivos de referência completos. Toda entrada no repo deve ser válida contra este schema.",
  "type": "object",

  "$defs": {
    "isoDate": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "Data no formato YYYY-MM-DD"
    },
    "kebabId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "Identificador em kebab-case lowercase"
    },
    "tagItem": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "Tag em lowercase kebab-case"
    },
    "tension": {
      "type": "string",
      "minLength": 5,
      "maxLength": 80,
      "description": "Paradoxo criativo — o que torna a referência interessante. Não é descrição, é divergência."
    },
    "maturity": {
      "type": "string",
      "enum": ["seed", "growing", "stable", "outdated", "deprecated"],
      "description": "seed=mínimo | growing=enriquecendo | stable=confiável | outdated=revisar | deprecated=histórico"
    },
    "referenceType": {
      "type": "string",
      "enum": ["site", "copy", "motion", "visual", "color-system", "industry", "competitor", "framework"],
      "description": "Natureza da referência — independente de onde está no repositório"
    }
  },

  "required": [
    "id",
    "type",
    "category",
    "name",
    "maturity",
    "tags",
    "tensions",
    "captured_at",
    "updated_at"
  ],

  "anyOf": [
    { "required": ["source_url"] },
    { "required": ["source_context"] }
  ],

  "properties": {
    "id": {
      "$ref": "#/$defs/kebabId",
      "description": "Identificador único no repositório"
    },
    "type": {
      "$ref": "#/$defs/referenceType"
    },
    "category": {
      "type": "string",
      "pattern": "^[a-z]+(/[a-z-]+)*$",
      "description": "Caminho da categoria — ex: sites/saas, copy, motion/gsap"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "description": "Nome legível da referência"
    },
    "source_url": {
      "type": "string",
      "format": "uri",
      "description": "URL exata da origem. Obrigatório se source_context ausente."
    },
    "source_context": {
      "type": "string",
      "minLength": 10,
      "description": "Descrição da origem quando não há URL verificável. Obrigatório se source_url ausente."
    },
    "captured_at": {
      "$ref": "#/$defs/isoDate",
      "description": "Data da primeira observação"
    },
    "updated_at": {
      "$ref": "#/$defs/isoDate",
      "description": "Data da última revisão substantiva"
    },
    "maturity": {
      "$ref": "#/$defs/maturity"
    },
    "tags": {
      "type": "array",
      "items": { "$ref": "#/$defs/tagItem" },
      "minItems": 3,
      "maxItems": 10,
      "uniqueItems": true,
      "description": "3–10 tags em kebab-case. Mínimo 2 domínios representados (visual/funcional/setorial/técnico)."
    },
    "tensions": {
      "type": "array",
      "items": { "$ref": "#/$defs/tension" },
      "minItems": 1,
      "maxItems": 3,
      "description": "1–3 paradoxos criativos. Não descrições — divergências."
    },
    "summary": {
      "type": "string",
      "maxLength": 500,
      "description": "Resumo em prosa — o que esta referência ensina e quando usar"
    },
    "use_cases": {
      "type": "array",
      "items": { "type": "string", "maxLength": 120 },
      "maxItems": 8,
      "description": "Situações concretas onde esta referência é aplicável"
    },
    "related": {
      "type": "array",
      "items": { "$ref": "#/$defs/kebabId" },
      "description": "IDs de referências relacionadas no mesmo repositório"
    },
    "notes": {
      "type": "string",
      "description": "Observações livres — contexto de captura, nuances, cuidados de uso"
    },

    "acquisition_role": {
      "type": "string",
      "maxLength": 300,
      "description": "Como esta referência contribui para aquisição — o que ela remove ou resolve no funil"
    },

    "visual": {
      "type": "object",
      "description": "Dados visuais da referência (obrigatório para types: site, visual)",
      "properties": {
        "palette": {
          "type": "object",
          "description": "Cores observadas",
          "properties": {
            "background": { "type": "string" },
            "primary_text": { "type": "string" },
            "accent": { "type": "string" },
            "surface": { "type": "string" }
          }
        },
        "typography": {
          "type": "object",
          "properties": {
            "heading": { "type": "string" },
            "body": { "type": "string" },
            "weight_heading": { "type": "string" },
            "size_scale": { "type": "string" }
          }
        },
        "style": {
          "type": "string",
          "enum": ["clean", "dark", "bold", "editorial", "technical", "warm"],
          "description": "Estilo visual dominante"
        },
        "mood": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Palavras que descrevem o mood"
        },
        "layout_principles": {
          "type": "array",
          "items": { "type": "string" }
        },
        "screenshots": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["label", "path_or_url"],
            "properties": {
              "label": { "type": "string" },
              "path_or_url": { "type": "string" },
              "captured_at": { "$ref": "#/$defs/isoDate" }
            }
          }
        }
      }
    },

    "copy": {
      "type": "object",
      "description": "Padrões de copy observados (para types: site, copy)",
      "properties": {
        "headline_style": { "type": "string" },
        "cta_style": { "type": "string" },
        "voice": { "type": "string" },
        "hook_type": {
          "type": "string",
          "enum": ["provocacao", "dado-inesperado", "confissao", "pergunta-incomoda", "declaracao-com-posicao", "promessa-direta"]
        },
        "examples": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["text", "context"],
            "properties": {
              "text": { "type": "string" },
              "context": { "type": "string" },
              "source_url": { "type": "string" }
            }
          }
        },
        "patterns": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "structure", "example"],
            "properties": {
              "name": { "type": "string" },
              "structure": { "type": "string", "description": "Fórmula abstrata — ex: [Número] + [Resultado] + [Tempo]" },
              "example": { "type": "string" },
              "when_to_use": { "type": "string" }
            }
          }
        }
      }
    },

    "motion": {
      "type": "object",
      "description": "Dados de animação (para types: site, motion)",
      "properties": {
        "library": {
          "type": "string",
          "enum": ["gsap", "three-js", "rive", "lottie", "css", "framer-motion", "other"]
        },
        "complexity": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "performance_cost": {
          "type": "string",
          "enum": ["very-low", "low", "medium", "high"]
        },
        "code": {
          "type": "object",
          "properties": {
            "install": { "type": "string" },
            "html": { "type": "string" },
            "css": { "type": "string" },
            "js": { "type": "string" },
            "config_options": { "type": "object" }
          }
        },
        "analysis": {
          "type": "string",
          "description": "Para reels/sites: análise textual do motion — ritmo, cortes, duração do gancho"
        },
        "external_url": {
          "type": "string",
          "format": "uri",
          "description": "Link para vídeo/demo externo (não armazenar vídeo bruto no git)"
        }
      }
    },

    "competitor": {
      "type": "object",
      "description": "Dados de análise competitiva (obrigatório para type: competitor)",
      "properties": {
        "positioning": {
          "type": "string",
          "description": "Como o concorrente se posiciona no mercado"
        },
        "target_audience": {
          "type": "string"
        },
        "strengths": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "weaknesses": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "key_pages": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["label", "url"],
            "properties": {
              "label": { "type": "string" },
              "url": { "type": "string" },
              "notes": { "type": "string" }
            }
          }
        },
        "acquisition_model": {
          "type": "string",
          "description": "Como o concorrente adquire clientes — PLG, outbound, comunidade, parceiros, etc."
        },
        "last_reviewed": { "$ref": "#/$defs/isoDate" }
      }
    },

    "industry": {
      "type": "object",
      "description": "Perfil de indústria (obrigatório para type: industry)",
      "properties": {
        "description": { "type": "string" },
        "typical_brands": {
          "type": "array",
          "items": { "type": "string" }
        },
        "visual_conventions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "O que é esperado visualmente nesta indústria"
        },
        "visual_opportunities": {
          "type": "array",
          "items": { "type": "string" },
          "description": "O que quebraria padrão positivamente"
        },
        "copy_conventions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "trust_signals": {
          "type": "array",
          "items": { "type": "string" }
        },
        "regulatory_notes": {
          "type": "string",
          "description": "Restrições legais ou regulatórias que afetam copy e visual"
        },
        "acquisition_model": {
          "type": "string",
          "description": "Modelo predominante de aquisição nessa indústria — referral, search, eventos, outbound, etc."
        }
      }
    }
  },

  "additionalProperties": false
}
