# ── LLM Providers ────────────────────────────────────────────────────────────
# Padrão: claude_code → usa o CLI `claude` autenticado no VS Code, sem API key.
# Para usar a API diretamente, troque para "anthropic" e preencha a chave.
LLM_PROVIDER=claude_code
LLM_MODEL=                            # vazio = usa o modelo padrão do provider

# Só necessário se LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...

# ── Storage ───────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/agents.db   # MVP
# DATABASE_URL=postgresql://user:pass@localhost:5432/social_agents  # produção

# ── Plataformas de publicação (opcional — só para PublishingAgent) ────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=

META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=

TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=

TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development                   # development | production
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
